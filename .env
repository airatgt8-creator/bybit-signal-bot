# Telegram
TELEGRAM_BOT_TOKEN=put_your_bot_token_here
TELEGRAM_CHAT_ID=put_your_chat_id_here

# Bybit (optional for auto-buy)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true
ENABLE_AUTO_BUY=false
ORDER_USDT_PER_TRADE=10
MAX_OPEN_POSITIONS=3
STOP_LOSS_PCT=0.08
TAKE_PROFIT_PCT=0.18

# Scanner
SCAN_INTERVAL_SECONDS=60
MIN_LIQUIDITY_USD=100000
MIN_VOLUME_5M_USD=150000
MIN_PRICE_CHANGE_5M_PCT=3
MAX_PRICE_CHANGE_1H_PCT=35
MIN_BUY_SELL_RATIO=1.15
MIN_UNIQUE_BUYERS=20
CHAIN_FILTER=solana,base,ethereum,bsc
WATCHLIST_BYBIT_SYMBOLS=PEPEUSDT,DOGEUSDT,BOMEUSDT,NOTUSDT,BONKUSDT,FLOKIUSDT,WIFUSDT,POPCATUSDT,SHIB1000USDT

# Optional X/Twitter module placeholder
ENABLE_X_MODULE=false
X_BEARER_TOKEN=
X_QUERY=(buy OR gem OR moon OR breakout) lang:en -is:retweet
